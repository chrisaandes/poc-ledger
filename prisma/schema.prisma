generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MerchantType {
  SALUD
  RETAIL
  EDUCACION
  OTRO
}

enum MerchantStatus {
  ACTIVE
  INACTIVE
}

model Merchant {
  id              String          @id @default(uuid())
  name            String
  type            MerchantType    @default(OTRO)
  commissionPct   Float           @default(3.0) @map("commission_pct")
  walletEnabled   Boolean         @default(false) @map("wallet_enabled")
  status          MerchantStatus  @default(ACTIVE)
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("merchants")
}
